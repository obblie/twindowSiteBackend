{
  "name": "twindow-license-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Render-ready backend license API for Twindow + Lemon Squeezy",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
